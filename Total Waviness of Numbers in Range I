class Solution:
    def totalWaviness(self, num1: int, num2: int) -> int:
        tot=0
        for i in range(num1,num2+1):
            x=str(i)
            for j in range(1,len(x)-1):
                if int(x[j-1])<int(x[j]) and int(x[j])>int(x[j+1]):
                    tot+=1
                elif int(x[j-1])>int(x[j]) and int(x[j])<int(x[j+1]):
                    tot+=1
        return tot
