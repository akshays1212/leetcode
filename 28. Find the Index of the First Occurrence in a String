class Solution:
    def strStr(self, haystack: str, needle: str) -> int:
        n=len(haystack)
        m=len(needle)
        k=0
        for i in range(n):
            if haystack[i]==needle[k] and i+m<=n:
                if haystack[i:i+m]==needle:
                    return i
        
        return -1
